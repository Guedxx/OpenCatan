{
  "name": "@catan/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --target node20 --clean --out-dir dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@catan/core": "workspace:*",
    "@catan/protocol": "workspace:*",
    "boardgame.io": "0.50.2",
    "cors": "2.8.5",
    "express": "5.1.0",
    "socket.io": "4.8.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.1",
    "@types/node": "22.13.10",
    "tsup": "8.4.0",
    "tsx": "4.19.3",
    "typescript": "5.8.2"
  }
}
