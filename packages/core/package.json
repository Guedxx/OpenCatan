{
  "name": "@catan/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch --clean --out-dir dist",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist"
  },
  "devDependencies": {
    "tsup": "8.4.0",
    "typescript": "5.8.2"
  }
}
